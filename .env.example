## Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

## App URL (required for Stripe redirects + email links)
# Must match the production domain or http://localhost:3000 for development
NEXT_PUBLIC_APP_URL=https://subsight-tracker.vercel.app

## Groq AI (Pro feature - subscription autofill + spending analysis)
GROQ_API_KEY=your_groq_api_key_here

## Google OAuth (configured in Supabase Auth settings)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

## Stripe (Pro billing)
# Create products/prices in Stripe Dashboard, set the price ID here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PRICE_ID=price_your_stripe_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

## SMTP (Pro email reminders via Nodemailer)
# Gmail App Password recommended: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@subsight.com

## Cron security (Vercel Cron -> /api/reminders/send && /api/keep-alive)
# Generate with: openssl rand -hex 32
CRON_SECRET=generate-a-random-secret-here
