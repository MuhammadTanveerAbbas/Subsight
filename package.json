{
  "name": "subsight",
  "version": "3.0.0",
  "description": "Modern subscription tracking app with AI-powered insights",
  "author": "Muhammad Tanveer Abbas <https://themvpguy.vercel.app/>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MuhammadTanveerAbbas/Subsight-Tracker"
  },
  "homepage": "https://subsight-tracker.vercel.app",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "pnpm typecheck",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "validate:env": "node -e \"if(!process.env.GROQ_API_KEY)throw new Error('GROQ_API_KEY required')\"",
    "audit": "pnpm audit --audit-level=moderate",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:watch": "vitest watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.89.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "groq-sdk": "^1.1.1",
    "lucide-react": "^0.475.0",
    "next": "^16.2.6",
    "nodemailer": "^8.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.1",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^5.1.0",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
